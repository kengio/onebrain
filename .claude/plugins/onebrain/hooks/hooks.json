{
  "SessionStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "onebrain session-init"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Write|Edit",
      "hooks": [
        {
          "type": "command",
          "command": "bash \".claude/plugins/onebrain/hooks/qmd-reindex.sh\""
        }
      ]
    }
  ]
}
